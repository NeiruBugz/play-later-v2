{
  "name": "savepoint-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 6060",
    "build": "prisma generate && vite build",
    "start": "node --env-file-if-exists=.env .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --project=unit",
    "test:unit:watch": "vitest --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx,md,json,css}\" --cache",
    "format": "prettier --write \"**/*.{ts,tsx,mdx,md,json,css}\" --cache",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test:db:clean": "node ./test/setup/clean-test-dbs.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@aws-sdk/s3-request-presigner": "3.1024.0",
    "@hookform/resolvers": "5.2.2",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@t3-oss/env-core": "0.13.11",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query": "5.90.12",
    "@tanstack/react-router": "1.170.4",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.6",
    "@tanstack/router-plugin": "1.132.0",
    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "0.545.0",
    "nitro": "3.0.260522-beta",
    "pg": "8.20.0",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "react": "19.2.0",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.68.0",
    "react-icons": "5.5.0",
    "sonner": "2.0.7",
    "tailwind-merge": "2.6.0",
