# Database Configuration
# PostgreSQL connection strings for Prisma and application
POSTGRES_PRISMA_URL=postgresql://your_postgres_user:your_postgres_password@localhost:6432/savepoint-db
POSTGRES_URL_NON_POOLING=postgresql://your_postgres_user:your_postgres_password@localhost:6432/savepoint-db
POSTGRES_URL=postgresql://your_postgres_user:your_postgres_password@localhost:6432/savepoint-db
POSTGRES_USER=your_postgres_user
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=savepoint-db
POSTGRES_URL_NO_SSL=postgresql://your_postgres_user:your_postgres_password@localhost:6432/savepoint-db

# Database Query Logging (Development Only)
# DATABASE_LOGGING=true

# Authentication (Better Auth)
# Same secret + URL family as savepoint-app/.env.local. Sessions interoperate
# across both apps because they share BETTER_AUTH_SECRET and the DB session table.
BETTER_AUTH_SECRET=your_better_auth_secret_here
# savepoint-tanstack runs on :6061 in dev (savepoint-app uses :6060)
BETTER_AUTH_URL=http://localhost:6061

# AWS Cognito (Upstream Identity Provider — Google federation)
AUTH_COGNITO_ID=your_cognito_app_client_id
AUTH_COGNITO_SECRET=your_cognito_app_client_secret
AUTH_COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<userPoolId>
AUTH_COGNITO_DOMAIN=your-app.auth.<region>.amazoncognito.com

# AUTH_MIGRATION_CUTOVER_AT: ISO-8601 UTC. Leave empty post-cutover.
AUTH_MIGRATION_CUTOVER_AT=

# Development/Testing Only
AUTH_ENABLE_CREDENTIALS=false

# Legacy (Optional - Google OAuth being phased out)
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# External APIs
IGDB_CLIENT_ID=your_igdb_client_id
IGDB_CLIENT_SECRET=your_igdb_client_secret

# Steam API - Optional
STEAM_API_KEY=your_steam_api_key

# S3 Configuration (LocalStack for Development)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4568
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=savepoint-dev
S3_AVATAR_PATH_PREFIX=user-avatars/

# Rate Limiting (Upstash Redis) — leave empty in dev
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional logging level (fatal|error|warn|info|debug|trace|silent)
# LOG_LEVEL=info

# Set to any value to bypass env validation (use sparingly, e.g., in Docker build steps)
# SKIP_ENV_VALIDATION=
